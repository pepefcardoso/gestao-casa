{
  "compilerOptions": {
    "strict": true,
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@gestao-casa/shared-logic/*": ["libs/shared-logic/src/*"],
      "@gestao-casa/backend/db": ["libs/backend/src/db/schema.ts"],
      "@gestao-casa/backend/*": ["libs/backend/src/*"]
    }
  }
}
